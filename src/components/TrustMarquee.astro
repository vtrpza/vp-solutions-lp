---
const items = [
  "Projetos entregues no prazo",
  "Comunicação transparente",
  "Sem surpresas no orçamento",
  "Do zero ao produto final",
  "Suporte pós-lançamento",
  "Acompanhamento semanal",
];
---

<div class="py-10 overflow-hidden border-y border-border">
  <div class="flex gap-12 animate-marquee w-max">
    {[...items, ...items].map((item) => (
      <span class="text-sm font-semibold text-text-muted whitespace-nowrap uppercase tracking-widest flex items-center gap-3">
        {item}
        <span class="text-accent text-[8px]">●</span>
      </span>
    ))}
  </div>
</div>
