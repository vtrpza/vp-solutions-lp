---
---

<nav class="fixed top-0 w-full z-50 px-6 md:px-10 py-5 flex justify-between items-center border-b border-transparent transition-all duration-300">
  <a href="#" class="text-xl font-extrabold tracking-tight" data-magnetic>VP<span class="text-accent">.</span></a>

  <!-- Desktop links -->
  <ul class="hidden md:flex gap-8 list-none">
    <li><a href="#solucoes" class="nav-link">Soluções</a></li>
    <li><a href="#resultados" class="nav-link">Resultados</a></li>
    <li><a href="#como-funciona" class="nav-link">Como Funciona</a></li>
    <li><a href="#sobre" class="nav-link">Sobre</a></li>
    <li><a href="#contato" class="nav-link">Contato</a></li>
  </ul>

  <a href="#contato" class="hidden md:inline-flex bg-accent text-bg-primary px-5 py-2 rounded-lg text-[13px] font-semibold hover:bg-accent-light hover:shadow-[0_0_20px_var(--color-accent-glow)] transition-all animate-border-glow" data-magnetic>
    Quero Meu Projeto →
  </a>

  <!-- Mobile hamburger -->
  <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
    <span class="block w-6 h-[2px] bg-text-primary transition-all" id="bar1"></span>
    <span class="block w-6 h-[2px] bg-text-primary transition-all" id="bar2"></span>
    <span class="block w-6 h-[2px] bg-text-primary transition-all" id="bar3"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-bg-primary/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8 hidden">
  <a href="#solucoes" class="mobile-nav-link">Soluções</a>
  <a href="#resultados" class="mobile-nav-link">Resultados</a>
  <a href="#como-funciona" class="mobile-nav-link">Como Funciona</a>
  <a href="#sobre" class="mobile-nav-link">Sobre</a>
  <a href="#contato" class="mobile-nav-link">Contato</a>
  <a href="#contato" class="btn-primary mt-4">Quero Meu Projeto →</a>
</div>

<style>
  .nav-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.3s;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.3s;
  }
  .nav-link:hover {
    color: var(--color-accent-light);
  }
  .nav-link:hover::after {
    width: 100%;
  }
  .mobile-nav-link {
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: 24px;
    font-weight: 600;
    transition: color 0.3s;
    opacity: 0;
    transform: translateY(40px);
  }
  .mobile-nav-link:hover {
    color: var(--color-accent);
  }
</style>

<script>
  import { gsap } from 'gsap';

  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  const mobileLinks = menu?.querySelectorAll('.mobile-nav-link, .btn-primary');

  let isOpen = false;

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    menu?.classList.toggle('hidden');

    if (isOpen) {
      bar1!.style.transform = 'rotate(45deg) translate(4px, 4px)';
      bar2!.style.opacity = '0';
      bar3!.style.transform = 'rotate(-45deg) translate(4px, -4px)';

      // GSAP stagger mobile links in
      if (mobileLinks) {
        gsap.fromTo(mobileLinks, {
          opacity: 0,
          y: 40,
        }, {
          opacity: 1,
          y: 0,
          duration: 0.4,
          stagger: 0.08,
          ease: 'power3.out',
        });
      }
    } else {
      bar1!.style.transform = '';
      bar2!.style.opacity = '';
      bar3!.style.transform = '';
    }
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      isOpen = false;
      menu.classList.add('hidden');
      bar1!.style.transform = '';
      bar2!.style.opacity = '';
      bar3!.style.transform = '';
    });
  });
</script>
