---
const featuredProject = {
  tag: "API / Inteligência Artificial",
  title: "VP Solutions Content API",
  description: "Nosso próprio produto — e a melhor prova do que sabemos fazer. Uma API robusta que gera artigos completos com inteligência artificial: título otimizado, corpo estruturado, imagens via Cloudinary, metadata SEO pronta para ranquear e tradução automática para múltiplos idiomas. Integra direto com WordPress via webhook, transformando a publicação de conteúdo em um processo 100% automatizado.",
  techs: ["Hono", "TypeScript", "GPT-4.1", "Cloudinary", "SQLite"],
};
---

<section id="resultados" class="py-16 md:py-24 px-5 md:px-10 max-w-[1100px] mx-auto">
  <div class="text-[11px] font-semibold uppercase tracking-[3px] text-accent mb-4 reveal">Nosso Produto</div>
  <h2 class="text-2xl md:text-[44px] font-bold tracking-tight mb-3 md:mb-4" data-split="words">Construímos para nós primeiro</h2>
  <p class="text-sm md:text-base text-text-secondary max-w-[560px] mb-8 md:mb-14 reveal reveal-delay-2">
    Antes de construir para você, criamos nosso próprio produto com as mesmas tecnologias e padrão de qualidade. Transparência total — aqui está o que já entregamos.
  </p>

  <!-- Featured Project — Full width -->
  <div class="project-featured glass-card overflow-hidden border-accent/20 hover:border-accent/40 transition-all duration-500 hover:shadow-[0_20px_80px_rgba(6,182,212,0.12)]">
    <div class="grid grid-cols-1 lg:grid-cols-2">
      <!-- Terminal mockup -->
      <div class="p-5 sm:p-6 lg:p-8 flex items-center justify-center bg-gradient-to-br from-[#0c1520] to-[#0a1018] relative overflow-hidden min-h-[240px] sm:min-h-[300px]">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-glow to-transparent"></div>
        <div class="terminal w-full max-w-[440px] relative z-10">
          <div class="terminal-header">
            <div class="dot bg-[#ff5f57]"></div>
            <div class="dot bg-[#febc2e]"></div>
            <div class="dot bg-[#28c840]"></div>
            <span class="text-[11px] text-text-muted ml-2 font-mono">response.json</span>
          </div>
          <div class="terminal-body">
            <pre class="terminal-output whitespace-pre text-[13px]"></pre><span class="terminal-cursor"></span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="p-6 lg:p-8 flex flex-col justify-center">
        <div class="text-[11px] text-accent font-semibold uppercase tracking-wider mb-2">{featuredProject.tag}</div>
        <h3 class="text-2xl font-bold mb-3">{featuredProject.title}</h3>
        <p class="text-sm text-text-secondary leading-relaxed mb-5">{featuredProject.description}</p>
        <div class="flex flex-wrap gap-1.5">
          {featuredProject.techs.map((tech) => (
            <span class="text-[11px] px-2.5 py-1 bg-bg-secondary border border-accent/20 rounded-md text-accent-light font-mono">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>

</section>
