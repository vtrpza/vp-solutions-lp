---
---

<footer class="relative py-14 px-6 text-center">
  <!-- Animated gradient divider -->
  <div class="absolute top-0 left-0 right-0 h-px overflow-hidden">
    <div class="h-full w-full bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
    <div class="absolute top-0 left-0 h-full w-1/4 bg-gradient-to-r from-transparent via-accent to-transparent animate-gradient-sweep" style="background-size: 200% 100%;"></div>
  </div>

  <div class="max-w-[1100px] mx-auto">
    <!-- Back to top -->
    <button id="back-to-top" class="mx-auto mb-8 w-10 h-10 rounded-full border border-border bg-bg-card/60 backdrop-blur-sm flex items-center justify-center text-text-muted hover:text-accent hover:border-accent/40 transition-all" data-magnetic aria-label="Voltar ao topo">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 19V5"/>
        <path d="m5 12 7-7 7 7"/>
      </svg>
    </button>

    <p class="text-text-muted/60 text-sm mb-3 reveal">
      Feito com código limpo e café forte. ☕
    </p>
    <p class="text-text-muted text-[13px] reveal reveal-delay-1">© 2026 VP Solutions. Todos os direitos reservados.</p>
  </div>
</footer>

<script>
  const btn = document.getElementById('back-to-top');
  btn?.addEventListener('click', () => {
    // Use Lenis if available, fallback to native
    const lenis = (window as any).__lenis;
    if (lenis) {
      lenis.scrollTo(0);
    } else {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
</script>
