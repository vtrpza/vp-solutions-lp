<section id="contato" class="py-24 px-6 md:px-10 max-w-[700px] mx-auto text-center">
  <div class="relative bg-gradient-to-br from-accent/[0.08] to-bg-card border border-accent/20 rounded-3xl p-10 md:p-14 overflow-hidden reveal">
    <!-- Top accent line -->
    <div class="absolute top-[-2px] left-[20%] right-[20%] h-[2px] bg-gradient-to-r from-transparent via-accent to-transparent"></div>

    <!-- Ambient orb -->
    <div class="absolute bottom-[-100px] right-[-100px] w-[300px] h-[300px] bg-[radial-gradient(circle,rgba(6,182,212,0.08),transparent_70%)] pointer-events-none"></div>

    <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-4 relative">
      Pronto para tirar sua<br>ideia do papel?
    </h2>
    <p class="text-text-secondary mb-8 text-base relative">
      Me conta sobre seu projeto. Respondo em até 24 horas — sem compromisso.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center relative mb-6">
      <a href="#" class="btn-primary">WhatsApp</a>
      <a href="#" class="btn-secondary">Enviar Email</a>
    </div>

    <p class="text-sm text-text-muted relative">
      Sem termos técnicos. Sem enrolação. Só uma conversa honesta sobre sua ideia.
    </p>
  </div>
</section>
