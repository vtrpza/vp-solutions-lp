---
const steps = [
  {
    number: "01",
    title: "Você conta sua ideia",
    description: "Conversamos sobre o que você imagina. Sem termos técnicos, sem complicação. Só sua visão.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v.01"/><path d="M8 11h8"/><path d="M8 7h2"/></svg>`,
  },
  {
    number: "02",
    title: "Nós planejamos tudo",
    description: "Transformamos sua ideia em um plano visual claro. Você aprova cada detalhe antes de começarmos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M9 14l2 2 4-4"/></svg>`,
  },
  {
    number: "03",
    title: "Construímos juntos",
    description: "Você acompanha o progresso toda semana. Vê seu produto ganhar vida, tela por tela.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/><path d="M2 10h20"/></svg>`,
  },
  {
    number: "04",
    title: "Seu produto no ar",
    description: "Lançamos, testamos, e garantimos que tudo funciona. E continuamos ao seu lado depois.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
  },
];
---

<section id="como-funciona" class="py-24 px-6 md:px-10 max-w-[1100px] mx-auto">
  <div class="text-center mb-14">
    <div class="text-[11px] font-semibold uppercase tracking-[3px] text-accent mb-4 reveal">Como Funciona</div>
    <h2 class="text-3xl md:text-[44px] font-bold tracking-tight mb-4 reveal reveal-delay-1">Do sonho ao produto real</h2>
    <p class="text-base text-text-secondary max-w-[560px] mx-auto reveal reveal-delay-2">
      Você não precisa entender de tecnologia. Só precisa ter uma boa ideia.
    </p>
  </div>

  <div class="relative grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Connecting line (desktop only) -->
    <div class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-30"></div>

    {steps.map((step, i) => (
      <div class={`text-center p-8 relative reveal reveal-delay-${i + 1}`}>
        <div class="w-12 h-12 mx-auto mb-5 rounded-xl bg-gradient-to-br from-accent/15 to-transparent border border-accent/20 flex items-center justify-center text-accent transition-all">
          <Fragment set:html={step.icon} />
        </div>
        <div class="text-5xl font-extrabold bg-gradient-to-b from-accent to-transparent bg-clip-text text-transparent opacity-50 mb-4 leading-none">
          {step.number}
        </div>
        <h3 class="text-base font-semibold mb-2">{step.title}</h3>
        <p class="text-[13px] text-text-secondary leading-relaxed">{step.description}</p>
      </div>
    ))}
  </div>
</section>
