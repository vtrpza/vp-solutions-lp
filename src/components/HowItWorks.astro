---
const steps = [
  {
    number: "01",
    painLine: "Cansou de preencher formulário e esperar 5 dias por um orçamento genérico?",
    title: "Conversa sem filtro, sem burocracia.",
    bullets: [
      "<strong>Call de 30 min</strong> — você explica sua ideia do seu jeito",
      "Eu faço as <strong>perguntas certas</strong> pra entender o problema real",
      "Você sai com <strong>escopo, prazo e investimento</strong> definidos",
      "<strong>Zero surpresa.</strong> Zero enrolação.",
    ],
    proofs: [
      { value: "30 min", label: "Clareza total" },
      { value: "R$ 0", label: "Sem custo inicial" },
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v.01"/><path d="M8 11h8"/><path d="M8 7h2"/></svg>`,
  },
  {
    number: "02",
    painLine: "Já teve projeto onde o dev começou a codar sem entender o que você precisava?",
    title: "Estratégia antes de cada pixel.",
    bullets: [
      "<strong>Wireframes navegáveis</strong> que você testa antes do código",
      "<strong>Arquitetura técnica</strong> definida e aprovada por você",
      "Cada decisão <strong>justificada</strong> — nada de 'achismo'",
      "<strong>Retrabalho eliminado</strong> na raiz",
    ],
    proofs: [
      { value: "0", label: "Retrabalho" },
      { value: "100%", label: "Suas decisões" },
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M9 14l2 2 4-4"/></svg>`,
  },
  {
    number: "03",
    painLine: "Já contratou alguém que sumiu por 3 meses e apareceu com algo que você não pediu?",
    title: "Você acompanha cada entrega, toda semana.",
    bullets: [
      "<strong>Versão funcional</strong> toda semana no seu celular",
      "<strong>Link privado</strong> pra testar e dar feedback direto",
      "Mudou de ideia? <strong>Ajusta no próximo ciclo</strong>",
      "Ágil de verdade, <strong>sem teatro corporativo</strong>",
    ],
    proofs: [
      { value: "7 dias", label: "Ciclo de entrega" },
      { value: "Ao vivo", label: "No seu celular" },
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/><path d="M2 10h20"/></svg>`,
  },
  {
    number: "04",
    painLine: "Já lançou um produto e ficou sozinho quando deu problema?",
    title: "No ar — e eu continuo aqui.",
    bullets: [
      "<strong>Deploy otimizado:</strong> domínio, SSL, analytics, tudo pronto",
      "<strong>30 dias</strong> de monitoramento e correções inclusos",
      "Ajustes finos baseados em <strong>dados reais de uso</strong>",
      "<strong>Suporte contínuo</strong> pra evoluir com você",
    ],
    proofs: [
      { value: "30 dias", label: "Suporte incluso" },
      { value: "24/7", label: "Monitoramento" },
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
  },
];
---

<section id="como-funciona" class="relative">
  <!-- Section header -->
  <div class="py-16 md:py-24 pb-12 md:pb-16 px-5 md:px-10 max-w-[1100px] mx-auto text-center">
    <!-- Pain hook (mono font, terminal-feel) -->
    <p class="font-mono text-sm md:text-base text-text-muted mb-6 max-w-[600px] mx-auto hiw-pain-hook" data-hiw-typewriter>
      Você já perdeu dinheiro com devs que sumiram. Projetos que atrasaram meses.
      Entregas que não tinham nada a ver com o que você pediu.
    </p>

    <!-- Label -->
    <div class="text-[11px] font-semibold uppercase tracking-[3px] text-accent mb-4 reveal">
      Como Funciona
    </div>

    <!-- Emotional pivot H2 -->
    <h2 class="text-2xl md:text-[44px] font-bold tracking-tight mb-3 md:mb-4" data-split="words">
      Aqui, o jogo é diferente.
    </h2>

    <!-- Sub -->
    <p class="text-base text-text-secondary max-w-[560px] mx-auto reveal reveal-delay-2">
      4 etapas. Você no controle de todas elas. Sem surpresas, sem enrolação.
    </p>
  </div>

  <!-- ====== DESKTOP: Pinned left/right layout (lg+) ====== -->
  <div class="hiw-scroll-container hidden lg:block relative" data-hiw-desktop>
    <div class="max-w-[1200px] mx-auto px-10 flex gap-16 min-h-screen relative">
      <!-- Left column (sticky) -->
      <div class="hiw-left w-[200px] flex-shrink-0 sticky top-0 h-screen flex items-center" data-hiw-left>
        <div class="flex flex-col items-center gap-8">
          <!-- Large step number -->
          <div class="hiw-step-number text-[120px] font-extrabold leading-none bg-gradient-to-b from-accent to-accent/20 bg-clip-text text-transparent" data-hiw-number>
            01
          </div>

          <!-- Progress bar with dots -->
          <div class="relative flex flex-col items-center gap-0 h-[200px]">
            <!-- Track -->
            <div class="absolute inset-0 w-px bg-border mx-auto"></div>
            <!-- Fill -->
            <div class="hiw-progress-fill absolute top-0 left-1/2 -translate-x-1/2 w-px bg-accent origin-top" style="height: 0%" data-hiw-progress></div>

            <!-- Dots -->
            {steps.map((_, i) => (
              <div
                class={`hiw-dot relative z-10 w-3 h-3 rounded-full border-2 border-border bg-bg-primary transition-colors duration-300 ${i === 0 ? 'border-accent bg-accent' : ''}`}
                data-hiw-dot={i}
                style={`margin-top: ${i === 0 ? '0' : 'auto'}`}
              />
            ))}
          </div>

          <!-- Active step icons (toggle visibility) -->
          <div class="relative w-14 h-14">
            {steps.map((step, i) => (
              <div
                class={`absolute inset-0 rounded-2xl bg-gradient-to-br from-accent/15 to-transparent border border-accent/20 flex items-center justify-center text-accent transition-opacity duration-300 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
                data-hiw-icon={i}
              >
                <Fragment set:html={step.icon} />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right column (scrolls) -->
      <div class="flex-1">
        {steps.map((step, i) => (
          <div class="hiw-panel min-h-[80vh] flex items-center py-16" data-hiw-panel={i}>
            <div class="max-w-[600px]">
              <!-- Pain micro-statement -->
              <p class="font-mono text-sm italic text-text-muted mb-4 opacity-0" data-hiw-content>
                "{step.painLine}"
              </p>

              <!-- Etapa label -->
              <div class="text-[11px] font-semibold uppercase tracking-[3px] text-accent mb-3 opacity-0" data-hiw-content>
                Etapa {step.number}
              </div>

              <!-- Title -->
              <h3 class="text-2xl lg:text-3xl font-bold mb-6 opacity-0" data-hiw-content>
                {step.title}
              </h3>

              <!-- Bullet list -->
              <ul class="space-y-3 mb-8">
                {step.bullets.map((bullet) => (
                  <li class="flex items-start gap-3 text-text-secondary opacity-0" data-hiw-content>
                    <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span set:html={bullet} />
                  </li>
                ))}
              </ul>

              <!-- Proof badges -->
              <div class="flex gap-3 flex-wrap">
                {step.proofs.map((proof) => (
                  <div class="glass-card px-5 py-3 flex flex-col items-center min-w-[100px] opacity-0" data-hiw-content>
                    <span class="text-lg font-bold text-accent">{proof.value}</span>
                    <span class="text-[11px] text-text-muted uppercase tracking-wider">{proof.label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ====== MOBILE: Vertical timeline (<lg) ====== -->
  <div class="lg:hidden px-5 md:px-10 max-w-[700px] mx-auto pb-16 md:pb-24" data-hiw-mobile>
    <!-- Sticky progress dots -->
    <div class="sticky top-4 z-20 flex justify-center gap-3 mb-8 py-2">
      {steps.map((_, i) => (
        <div
          class={`hiw-mobile-dot w-2.5 h-2.5 rounded-full border border-border bg-bg-primary ${i === 0 ? 'bg-accent border-accent' : ''}`}
          data-hiw-mobile-dot={i}
        />
      ))}
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Timeline track -->
      <div class="absolute left-[11px] top-0 bottom-0 w-px bg-border"></div>
      <!-- Timeline fill -->
      <div class="hiw-mobile-line-fill absolute left-[11px] top-0 w-px bg-accent origin-top" style="height: 0%" data-hiw-mobile-line></div>

      {steps.map((step, i) => (
        <div class="hiw-mobile-panel relative pl-10 pb-16" data-hiw-mobile-panel={i}>
          <!-- Timeline dot -->
          <div
            class={`hiw-mobile-step-dot absolute left-0 top-1 w-[23px] h-[23px] rounded-full border-2 border-border bg-bg-primary flex items-center justify-center z-10 ${i === 0 ? 'border-accent' : ''}`}
            data-hiw-mobile-step-dot={i}
          >
            <div class={`w-2 h-2 rounded-full ${i === 0 ? 'bg-accent' : 'bg-border'}`} data-hiw-mobile-step-inner={i}></div>
          </div>

          <!-- Pain micro-statement -->
          <p class="font-mono text-xs italic text-text-muted mb-3 reveal">
            "{step.painLine}"
          </p>

          <!-- Etapa label -->
          <div class="text-[11px] font-semibold uppercase tracking-[3px] text-accent mb-2 reveal">
            Etapa {step.number}
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold mb-4 reveal">
            {step.title}
          </h3>

          <!-- Bullet list -->
          <ul class="space-y-2.5 mb-6">
            {step.bullets.map((bullet) => (
              <li class="flex items-start gap-2.5 text-sm text-text-secondary reveal">
                <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span set:html={bullet} />
              </li>
            ))}
          </ul>

          <!-- Proof badges -->
          <div class="flex gap-2.5 flex-wrap">
            {step.proofs.map((proof) => (
              <div class="glass-card px-3 sm:px-4 py-2 sm:py-2.5 flex flex-col items-center min-w-[80px] sm:min-w-[90px] reveal">
                <span class="text-base font-bold text-accent">{proof.value}</span>
                <span class="text-[10px] text-text-muted uppercase tracking-wider">{proof.label}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
