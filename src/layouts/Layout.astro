---
import '../styles/global.css';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>VP Solutions — Seu Produto Digital do Zero ao Deploy, Sem Intermediários</title>
    <meta name="description" content="Desenvolvedor sênior com 10+ anos construindo SaaS, sites e sistemas sob medida. Você fala direto comigo, acompanha cada etapa, e paga preço justo. Fale comigo hoje." />

    <!-- OG Tags -->
    <meta property="og:title" content="VP Solutions — Seu Produto Digital do Zero ao Deploy, Sem Intermediários" />
    <meta property="og:description" content="Desenvolvedor sênior com 10+ anos construindo SaaS, sites e sistemas sob medida. Você fala direto comigo, acompanha cada etapa, e paga preço justo." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Non-blocking Google Fonts (preload → stylesheet swap) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      />
    </noscript>

    <noscript>
      <style>
        .page-loader { display: none !important; }
        .reveal { opacity: 1 !important; transform: none !important; }
        .cursor-dot, .cursor-ring, .cursor-glow { display: none !important; }
        .hiw-panel [data-hiw-content], .hiw-mobile-panel { opacity: 1 !important; transform: none !important; }
        .hiw-pain-hook::after { display: none !important; }
        .faq-content { height: auto !important; overflow: visible !important; }
        .faq-inner { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>
  </head>
  <body>
    <!-- Page loader -->
    <div class="page-loader"></div>

    <!-- Custom cursor -->
    <div class="cursor-dot"></div>
    <div class="cursor-ring"></div>

    <!-- Background effects -->
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <canvas id="particles" class="fixed inset-0 z-0 pointer-events-none"></canvas>
    <div class="cursor-glow" id="cursorGlow"></div>

    <!-- Content -->
    <div class="relative z-[1]">
      <slot />
    </div>

    <!-- Client scripts -->
    <script>
      import '../scripts/smooth-scroll';
      import '../scripts/page-loader';
      import '../scripts/hero-entrance';
      import '../scripts/gsap-animations';
      import '../scripts/hiw-scroll';
      import '../scripts/particles';
      import '../scripts/adam-hands';
      import '../scripts/custom-cursor';
      import '../scripts/magnetic';
      import '../scripts/card-tilt';
      import '../scripts/text-reveal';
      import '../scripts/faq-accordion';
      import '../scripts/terminal-typing';
      import '../scripts/counter';
    </script>
  </body>
</html>
