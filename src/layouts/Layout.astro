---
import '../styles/global.css';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>VP Solutions — Transformamos Ideias em Produtos Digitais</title>
    <meta name="description" content="Você tem a ideia, nós temos a expertise. Transformamos seu sonho em um produto digital de verdade — do zero ao lançamento. Sem termos técnicos, sem complicação." />

    <!-- OG Tags -->
    <meta property="og:title" content="VP Solutions — Transformamos Ideias em Produtos Digitais" />
    <meta property="og:description" content="Você tem a ideia, nós temos a expertise. Transformamos seu sonho em um produto digital de verdade — do zero ao lançamento." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Background effects -->
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <canvas id="particles" class="fixed inset-0 z-0 pointer-events-none"></canvas>
    <div class="cursor-glow" id="cursorGlow"></div>

    <!-- Content -->
    <div class="relative z-[1]">
      <slot />
    </div>

    <!-- Client scripts -->
    <script>
      import '../scripts/particles';
      import '../scripts/cursor-glow';
      import '../scripts/scroll-reveal';
      import '../scripts/counter';
    </script>
  </body>
</html>
